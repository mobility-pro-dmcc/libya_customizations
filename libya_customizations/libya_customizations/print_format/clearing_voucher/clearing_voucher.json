 "html": "{%- from \"templates/print_formats/standard_macros.html\" import add_header,\r\n\t render_field -%}\r\n\r\n\r\n<div id=\"header-html\" >\r\n    <div class=\"letter-head\">{{ letter_head }}</div>\r\n    <div style=\"\">\r\n        <p style=\" margin-left:30mm;\"> \u0633\u0646\u062f \u0645\u0642\u0627\u0635\u0629 \u0631\u0642\u0645<span> <b> {{ doc.name }} </b> </span></p>\r\n    </div>\r\n</div>\r\n<div class=\"row\">\r\n\t<div class=\"col-xs-12 column-break\">\r\n\t\t<table class=\"table table-condensed table-bordered cart \" style=\"margin-top:1mm;\">\r\n        \t<tbody>\r\n        \t\t<tr>\r\n        \t\t\t<td>\r\n            \t\t\t<div>\r\n                           <label style=\"display: inline-block !important; white-space: nowrap;\">\u0645\u0642\u0627\u0635\u0629 \u0645\u0646</label>\r\n                        </div>\r\n                    </td>\r\n                    <td colspan=\"3\">\r\n                        <div>\r\n                        {% if doc.from_party_type %}\r\n                        \t {{ doc.from_party_name }}\r\n                        {% else %}\r\n                            {{ frappe.db.get_value('Account', doc.from_account, 'account_name') }}\r\n                        {% endif %}\r\n                        </div>\r\n                    </td>\r\n        \t\t\t<td>\r\n        \t\t\t   <div>\r\n                        <label style=\"display: inline-block !important;\">\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0625\u0635\u062f\u0627\u0631</label>\r\n                        </div>\r\n        \t\t\t</td>\r\n        \t\t\t<td>\r\n        \t\t\t   <div>\r\n                    \t{{ doc.posting_date }}\r\n                        </div>\r\n        \t\t\t</td>\r\n        \t\t</tr>\r\n    \t\t\t<tr>\r\n        \t\t\t<td>\r\n        \t\t\t   <div>\r\n                        <label style=\"display: inline-block !important; white-space: nowrap;\">\u0625\u0644\u0649 \u062d\u0633\u0627\u0628</label>\r\n                        </div>\r\n        \t\t\t</td>\r\n        \t\t\t<td colspan=\"5\">\r\n        \t\t\t   <div>\r\n                        {% if doc.to_party_type %}\r\n                        \t {{ doc.to_party_name }}\r\n                        {% else %}\r\n                            {{ frappe.db.get_value('Account', doc.to_account, 'account_name') }}\r\n                        {% endif %}\r\n                        </div>\r\n        \t\t\t</td>\r\n        \t\t</tr>\r\n        \t</tbody>\r\n        </table>\r\n\t</div>\r\n</div>\r\n<div class=\"row\">\r\n\t<div class=\"col-xs-12 column-break\">\r\n    \t<table class=\"table table-condensed table-bordered cart \">\r\n        \t<tbody class=\"text-center\">\r\n    \t\t\t<tr>\r\n        \t\t    <td><b>\u0645\u0628\u0644\u063a \u0627\u0644\u0645\u0642\u0627\u0635\u0629</b></td>\r\n        \t\t    {%if doc.to == 'Customer' %}\r\n            \t\t    <td><b>\u0631\u0635\u064a\u062f \u0627\u0644\u0639\u0645\u064a\u0644 (\u0628\u062f\u0648\u0646 \u0623\u0648\u0627\u0645\u0631 \u0627\u0644\u0628\u064a\u0639)</b></td>\r\n            \t\t    <td><b>\u0631\u0635\u064a\u062f \u0627\u0644\u0639\u0645\u064a\u0644 (\u0634\u0627\u0645\u0644 \u0623\u0648\u0627\u0645\u0631 \u0627\u0644\u0628\u064a\u0639)</b></td>\r\n        \t\t    {%endif%}\r\n        \t\t</tr>\r\n        \t\t<tr>\r\n                    <td>{{ frappe.format_value( doc.deducted_amount, {\"fieldtype\": \"Currency\", \"precision\": 2})  }}</td>\r\n                    {%if doc.to == 'Customer' %}\r\n        \t\t        {%set credit_balance_wo_so = get_customer_credit_balance_wo_so(doc.to_party, doc.company)%}\r\n        \t\t        {%set credit_balance_w_so = get_customer_credit_balance_w_so(doc.to_party, doc.company)%}\r\n                    \t<td>{{ frappe.format_value( credit_balance_wo_so, {\"fieldtype\": \"Currency\", \"precision\": 2})  }}</td>\r\n                    \t<td>{{ frappe.format_value( credit_balance_w_so, {\"fieldtype\": \"Currency\", \"precision\": 2})  }}</td>\r\n        \t\t    {%endif%}\r\n        \t\t</tr>\r\n        \t</tbody>\r\n        </table>\r\n\t\t<div class=\"row section-break text-center\">\r\n\t\t</div>\r\n    </div>\r\n</div>\r\n<div class=\"row text-center\" style=\"margin-top:10px\">\r\n    <div class=\"col-xs-4 column-break\">\r\n        <div>\u062a\u0648\u0642\u064a\u0639 \u0648\u062e\u062a\u0645 \u0627\u0644\u0634\u0631\u0643\u0629</div>\r\n    </div>\r\n    </div>\r\n\t<div id=\"footer-html\" class=\"visible-pdf\">\r\n\t\t<div class=\"letter-head-footer\">\r\n\t\t\t{{ footer }}\r\n\t\t</div>\r\n\t\t<p class=\"text-center small page-number visible-pdf\">\r\n\t\t\t{{ _(\"Page {0} of {1}\").format('<span class=\"page\"></span>', '<span class=\"topage\"></span>') }}\r\n\t\t</p>\r\n\t</div>",
